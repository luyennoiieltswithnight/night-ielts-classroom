rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity test path
    match /test/connection {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "nightruan31@gmail.com"; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Registry & Profile
    match /users/{userId} {
      // Admin can list users to find students to share with
      allow list: if isAdmin();
      // Users can manage their own profile
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'displayName']) &&
        incoming().uid == userId &&
        incoming().email == request.auth.token.email;
    }

    // Personal Data - Strictly Isolated
    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/lessons/{lessonId}/{subPath=**} {
      allow read, write: if isOwner(userId);
    }

    // Shared Resources Manager
    function isSharedTarget() {
      return existing().isPublic == true || 
             (request.auth.uid in existing().sharedWithUids) ||
             isAdmin();
    }

    match /sharedTopics/{topicId} {
      allow read: if isSignedIn() && isSharedTarget();
      allow write: if isAdmin() && isValidId(topicId);
    }

    match /sharedLessons/{lessonId} {
      allow read: if isSignedIn() && isSharedTarget();
      allow write: if isAdmin() && isValidId(lessonId);
    }

    match /sharedFolders/{folderId} {
      allow read: if isSignedIn() && isSharedTarget();
      allow write: if isAdmin() && isValidId(folderId);
    }
  }
}
